# Nova Researcher API Configuration

# ================= LLM CONFIGURATION =================
# LiteLLM supports any model. Format: <provider>/<model_name>
# Examples:
# GEMINI: google_ai/gemini-1.5-pro
# ANTHROPIC: anthropic/claude-3-5-sonnet-20240620
# OPENAI: gpt-4o

PI_MODEL=google_ai/gemini-1.5-pro
SWARM_MODEL=google_ai/gemini-1.5-flash

# API KEYS (Leave empty if using local Ollama or keyless proxies)
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# ================= LITERATURE CONFIGURATION =================
# OpenAlex and arXiv are keyless. 
# Optional email for OpenAlex 'Polite Pool' (Recommended for reliability)
OPENALEX_EMAIL=your_email@example.com
